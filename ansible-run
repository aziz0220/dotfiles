#!/usr/bin/env bash
set -euo pipefail

PLAYBOOK="${ANSIBLE_PLAYBOOK_FILE:-local.yml}"
TAG_SET="all"
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
BOOTSTRAP_HOME_DIR="${BOOTSTRAP_HOME_DIR:-$REPO_DIR/.bootstrap/home}"
ENCRYPTED_HOME_BUNDLE="${ENCRYPTED_HOME_BUNDLE:-$REPO_DIR/vault/home-secrets.tar.gz.aes256}"

if [ "$#" -gt 0 ] && [[ "$1" != -* ]]; then
  TAG_SET="$1"
  shift
fi

ANSIBLE_EXTRA_ARGS=("$@")

if ! command -v ansible-playbook >/dev/null 2>&1; then
  echo "ERROR: ansible-playbook is not installed. Run ./install first." >&2
  exit 1
fi

if [ ! -d "$BOOTSTRAP_HOME_DIR" ]; then
  if [ -f "$ENCRYPTED_HOME_BUNDLE" ]; then
    if [ -z "${SETUP_SECRETS_PASSWORD-}" ]; then
      echo "ERROR: missing $BOOTSTRAP_HOME_DIR and encrypted bundle exists at $ENCRYPTED_HOME_BUNDLE." >&2
      echo "Set SETUP_SECRETS_PASSWORD and rerun ./ansible-run to decrypt automatically." >&2
      exit 1
    fi
    "$REPO_DIR/scripts/decrypt_home_bundle.sh" "$ENCRYPTED_HOME_BUNDLE" "$BOOTSTRAP_HOME_DIR" "SETUP_SECRETS_PASSWORD"
  else
    echo "ERROR: missing bootstrap home source at $BOOTSTRAP_HOME_DIR." >&2
    echo "Create it or provide an encrypted bundle at $ENCRYPTED_HOME_BUNDLE." >&2
    exit 1
  fi
fi

CURRENT_USER="$(whoami)"
CURRENT_HOME="$HOME"
CURRENT_UID="$(id -u)"
CURRENT_GID="$(id -g)"
CURRENT_SHELL="$(basename "${SHELL:-/bin/zsh}")"
CURRENT_SHELL_PATH="$(command -v "$CURRENT_SHELL" 2>/dev/null || printf '/usr/bin/zsh')"

ANSIBLE_CMD=(
  ansible-playbook "$PLAYBOOK"
  -e "user_name=$CURRENT_USER"
  -e "user_home=$CURRENT_HOME"
  -e "user_uid=$CURRENT_UID"
  -e "user_gid=$CURRENT_GID"
  -e "user_shell=$CURRENT_SHELL_PATH"
)

if [ "$TAG_SET" != "all" ]; then
  ANSIBLE_CMD+=(--tags "$TAG_SET")
fi

ANSIBLE_CMD+=("${ANSIBLE_EXTRA_ARGS[@]}")

if [ "$(id -u)" -ne 0 ]; then
  if command -v sudo >/dev/null 2>&1; then
    ask_become_pass=false
    for arg in "${ANSIBLE_EXTRA_ARGS[@]}"; do
      if [ "$arg" = "-K" ] || [ "$arg" = "--ask-become-pass" ]; then
        ask_become_pass=true
        break
      fi
    done

    if [ "$ask_become_pass" = false ]; then
      sudo -v
    fi
  else
    echo "ERROR: sudo is required for become tasks." >&2
    exit 1
  fi
fi

echo "Bootstrapping as user: $CURRENT_USER ($CURRENT_HOME)"
"${ANSIBLE_CMD[@]}"
